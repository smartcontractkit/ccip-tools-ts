{
  "name": "@chainlink/ccip-cli",
  "version": "1.9.0",
  "description": "CCIP Command Line Interface, based on @chainlink/ccip-sdk",
  "author": "Chainlink devs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smartcontractkit/ccip-tools-ts.git"
  },
  "homepage": "https://docs.chain.link/ccip/tools/cli/",
  "bugs": {
    "url": "https://github.com/smartcontractkit/ccip-tools-ts/issues"
  },
  "type": "module",
  "bin": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "test": "node --test",
    "lint": "prettier --check ./src && eslint ./src",
    "lint:fix": "prettier --write ./src && eslint --fix ./src",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "build": "npm run clean && tsc -p ./tsconfig.build.json && npm run patch-dist",
    "patch-dist": "chmod +x ./dist/index.js && find ./dist -type f -name \"*.js\" -exec sed -i.bkp 's|@chainlink/ccip-sdk/src/.*\\.ts|@chainlink/ccip-sdk|g' {} + && find ./dist -type f -name \"*.bkp\" -delete",
    "start": "./ccip-cli",
    "clean": "rm -rfv ./dist",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "!**/*.test.*",
    "!**/__tests__",
    "!**/__mocks__"
  ],
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/update-notifier": "^6.0.8",
    "@types/yargs": "17.0.35",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^6.3.1",
    "@chainlink/ccip-sdk": "^1.9.0",
    "@coral-xyz/anchor": "^0.29.0",
    "@ethers-ext/signer-ledger": "^6.0.0-beta.1",
    "@inquirer/prompts": "8.5.2",
    "@ledgerhq/hw-app-aptos": "6.37.0",
    "@ledgerhq/hw-app-solana": "7.9.0",
    "@ledgerhq/hw-transport-node-hid": "6.32.0",
    "@mysten/sui": "^2.17.0",
    "@solana/web3.js": "^1.98.4",
    "@ton-community/ton-ledger": "^7.3.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "bs58": "^6.0.0",
    "ethers": "6.16.0",
    "type-fest": "^5.7.0",
    "update-notifier": "^7.3.1",
    "yargs": "18.0.0"
  }
}
