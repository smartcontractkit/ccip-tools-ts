{
  "name": "@chainlink/ccip-tools-ts",
  "version": "1.10.3",
  "description": "CLI and library to interact with CCIP",
  "author": "Chainlink devs",
  "license": "MIT",
  "repository": "git://github.com/smartcontractkit/ccip-tools-ts.git",
  "type": "module",
  "workspaces": [
    "ccip-sdk",
    "ccip-cli",
    "ccip-api-ref"
  ],
  "scripts": {
    "test": "npm run clean:coverage && c8 npm test -w ccip-sdk -w ccip-cli",
    "test:unit": "npm run clean:coverage && c8 npm test -w ccip-sdk",
    "test:e2e": "npm run clean:coverage && c8 npm test -w ccip-cli",
    "lint": "npm run lint --workspaces && npm run generate:lint",
    "lint:fix": "npm run lint:fix --workspaces && npm run generate",
    "typecheck": "npm run typecheck --workspaces",
    "check": "npm run lint && npm run typecheck && npm run generate:lint",
    "generate": "node ./generate.cjs `grep -lrn '^\\s*//\\s*generate\\b' ./ccip-sdk/src ./ccip-cli/src`",
    "generate:lint": "npm run generate -- --dry",
    "clean:coverage": "rm -rfv ./.coverage ./.c8_output",
    "clean": "npm run clean:coverage && npm run clean -w ccip-sdk -w ccip-cli",
    "build": "npm run clean && npm run build -w ccip-sdk -w ccip-cli",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "26.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-tsdoc": "^0.5.2",
    "glob": "13.0.6",
    "prettier": "3.9.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "yaml": "2.9.0"
  },
  "overrides": {
    "bigint-buffer": "npm:@trufflesuite/bigint-buffer@1.1.10",
    "axios": "^1.18.1",
    "tar": "^7.5.16",
    "elliptic": "6.6.1",
    "js-yaml": "^4.3.0",
    "gray-matter": {
      "js-yaml": "^3.15.0"
    },
    "postcss": "^8.5.15",
    "lodash": "^4.18.1",
    "uuid": "^11.1.1",
    "yaml@1": "^1.10.3",
    "serialize-javascript": "^7.0.5",
    "mermaid": "^11.15.0",
    "webpack-dev-server": "^5.2.4",
    "ws": "8.21.0",
    "form-data": "^4.0.6",
    "undici": "^7.28.0",
    "launch-editor": "^2.14.1",
    "shell-quote": "^1.8.4",
    "joi": "^18.2.1",
    "qs": "^6.15.2"
  }
}
